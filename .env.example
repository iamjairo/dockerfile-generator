# =============================================================================
# .env.example — Environment variables for Dockerfile Generator
# =============================================================================
# Copy this file to .env and fill in the values for the AI provider(s)
# you want to use.  You only need to set keys for the providers you have
# accounts with — the app will only show providers whose key is present.
#
# NEVER commit your real .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Cohere  (https://dashboard.cohere.com/)
# Model used: command-r-plus
# -----------------------------------------------------------------------------
COHERE_API_KEY=your_cohere_api_key_here

# -----------------------------------------------------------------------------
# OpenAI / ChatGPT  (https://platform.openai.com/api-keys)
# Default model: gpt-4o  — override with OPENAI_MODEL if needed
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Google Gemini  (https://aistudio.google.com/app/apikey)
# Model used: gemini-1.5-pro
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# Anthropic Claude  (https://console.anthropic.com/settings/keys)
# Model used: claude-3-5-sonnet-latest
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# Ollama (local — no API key required)
# Make sure Ollama is running:  ollama serve
# Default model: llama3  — override below if you have a different model pulled
# Default host: http://localhost:11434
# -----------------------------------------------------------------------------
# OLLAMA_MODEL=llama3
# OLLAMA_HOST=http://localhost:11434
